<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Restoring Hive can revive a stale local profile/device claim. Supabase
         stores its session in FlutterSharedPreferences; excluding that whole
         file is the Android-supported granularity and forces reauthentication. -->
    <cloud-backup>
        <exclude domain="root" path="app_flutter/connect_merge.hive" />
        <exclude domain="root" path="app_flutter/connect_merge.hivec" />
        <exclude domain="root" path="app_flutter/connect_merge.lock" />
        <exclude domain="sharedpref" path="FlutterSharedPreferences.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="app_flutter/connect_merge.hive" />
        <exclude domain="root" path="app_flutter/connect_merge.hivec" />
        <exclude domain="root" path="app_flutter/connect_merge.lock" />
        <exclude domain="sharedpref" path="FlutterSharedPreferences.xml" />
    </device-transfer>
</data-extraction-rules>
