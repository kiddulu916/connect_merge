# Credentials for connect_merge (Competitive Daily Expansion).
# Copy this file to `.env` (gitignored) and fill in real values.
# The Flutter app reads these via --dart-define at build/run time.
#
# Simplest: pass the whole file at once (Flutter 3.7+ reads key=value .env):
#
#   flutter run --dart-define-from-file=.env
#   flutter build apk --debug --dart-define-from-file=.env
#
# Find the Supabase values in: Project Settings -> API (URL + anon/publishable key).

# Project URL, e.g. https://abcdefghijklmnop.supabase.co
SUPABASE_URL=

# anon / publishable key (safe to ship in the client app)
SUPABASE_ANON_KEY=

# Google Sign-In WEB OAuth client ID (NOT the Android client), used as
# serverClientId. Google Cloud -> APIs & Services -> Credentials ->
# "Web client (auto created by Google Service)". Ends in
# .apps.googleusercontent.com. Safe to ship in the client app.
GOOGLE_WEB_CLIENT_ID=

# NOTE: the service_role (SECRET) key is NEVER stored here and NEVER committed.
# Supabase injects SUPABASE_SERVICE_ROLE_KEY into Edge Functions automatically
# (both in the cloud and via `supabase functions serve` against the local stack),
# so the replay-verification function gets it without manual handling.
